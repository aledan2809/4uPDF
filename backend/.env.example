# Database Configuration
# SQLite (development):
# DATABASE_URL=sqlite+aiosqlite:///./4updf.db
# PostgreSQL (production on VPS2 - 72.62.155.74):
DATABASE_URL=postgresql+asyncpg://4updf_user:CHANGE_THIS_PASSWORD@localhost/4updf

# Server Configuration
HOST=0.0.0.0
PORT=8000

# File Upload Limits
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_REQUEST=20

# File Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
FILE_RETENTION_HOURS=24

# Rate Limiting (Free Tier)
FREE_DAILY_LIMIT=10
FREE_MONTHLY_LIMIT=100

# Rate Limiting (Pro Tier)
PRO_DAILY_LIMIT=1000
PRO_MONTHLY_LIMIT=10000

# Security
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
CORS_ORIGINS=https://4updf.com,http://localhost:3098
FRONTEND_URL=https://4updf.com

# Stripe (for Pro tier subscription)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Redis (Optional - for task queue)
REDIS_URL=redis://localhost:6379/0

# Monitoring (Optional)
SENTRY_DSN=
