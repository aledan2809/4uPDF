# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./4updf.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost/4updf

# Server Configuration
HOST=0.0.0.0
PORT=8000

# File Upload Limits
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_REQUEST=20

# File Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
FILE_RETENTION_HOURS=24

# Rate Limiting (Free Tier)
FREE_DAILY_LIMIT=10
FREE_MONTHLY_LIMIT=100

# Rate Limiting (Pro Tier)
PRO_DAILY_LIMIT=1000
PRO_MONTHLY_LIMIT=10000

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Stripe (Optional - for Pro tier)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Redis (Optional - for task queue)
REDIS_URL=redis://localhost:6379/0

# Monitoring (Optional)
SENTRY_DSN=
