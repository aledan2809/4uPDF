# 4uPDF Production Environment Variables
# Copy to .env on VPS and fill in values

# PostgreSQL (replace SQLite)
DATABASE_URL=postgresql+asyncpg://4updf_user:YOUR_PASSWORD@localhost/4updf

# JWT Authentication
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Frontend URL (for Stripe redirects)
FRONTEND_URL=https://4updf.com
